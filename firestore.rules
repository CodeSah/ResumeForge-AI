rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (Pillar 1/10)
    match /{document=**} {
      allow read, write: if false;
    }

    // Identity and Authentication Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Resumes Collection Policy (Rule definitions per security specification)
    match /resumes/{userId} {
      allow get, delete: if isOwner(userId) && isValidId(userId);
      
      allow create: if isOwner(userId) && isValidId(userId) &&
        incoming().userId == userId &&
        incoming().personal != null &&
        incoming().personal.name is string &&
        incoming().personal.name.size() <= 200;
        
      allow update: if isOwner(userId) && isValidId(userId) &&
        incoming().userId == userId &&
        incoming().personal != null &&
        incoming().personal.name is string &&
        incoming().personal.name.size() <= 200;
    }
  }
}
